# =============================================================================
# STAGING ENVIRONMENT — backend/.env.staging.example
# Copy to backend/.env when working against the staging Railway service.
# NEVER use production values here.
# =============================================================================

# --- Server ---
PORT=3000
NODE_ENV=staging
FRONTEND_URL=https://<your-vercel-preview-or-staging-url>.vercel.app

# --- Supabase (STAGING project) ---
# Create a separate Supabase project at supabase.com for staging.
# Do NOT use the production SUPABASE_URL / SUPABASE_SERVICE_KEY here.
SUPABASE_URL=https://<staging-project>.supabase.co
SUPABASE_SERVICE_KEY=<staging-service-role-key>
SUPABASE_ANON_KEY=<staging-anon-key>

# --- MongoDB (STAGING database) ---
# Use a separate MongoDB Atlas cluster or a different database name.
MONGODB_SCRIPTS_URI=mongodb+srv://<user>:<pass>@<staging-cluster>.mongodb.net/hypnosis-scripts-staging

# --- Pinecone (STAGING indexes) ---
# Can reuse the same Pinecone API key but use -staging suffixed index names.
PINECONE_API_KEY=<shared-or-staging-pinecone-key>
PINECONE_ENVIRONMENT=<region>
PINECONE_INDEX_USER_INFO=user-information-staging
PINECONE_INDEX_KNOWLEDGE=core-hypnosis-knowledge-staging
PINECONE_INDEX_CREATIONS=past-creations-staging
PINECONE_INDEX_TRENDS=interest-trends-staging

# --- AI Models (shared keys are fine for staging) ---
OPENAI_API_KEY=<your-openai-key>
ANTHROPIC_API_KEY=<your-anthropic-key>
DEEPSEEK_API_KEY=<your-deepseek-key>
COHERE_API_KEY=<your-cohere-key>

# --- ElevenLabs ---
ELEVENLABS_API_KEY=<your-elevenlabs-key>
ELEVENLABS_VOICE_ID=<staging-voice-id>

# --- Google APIs ---
GOOGLE_CREDENTIALS_JSON=path-to-service-account.json
GOOGLE_DRIVE_FOLDER_ID=<staging-drive-folder-id>

# --- Gmail ---
GMAIL_USER=<your-gmail>
GMAIL_APP_PASSWORD=<app-password>

# --- n8n (STAGING webhook) ---
# Use a separate n8n workflow or the test webhook URL.
N8N_WEBHOOK_URL=<staging-n8n-webhook-url>
N8N_API_KEY=<n8n-api-key>

# --- JWT ---
JWT_SECRET=staging-jwt-secret-change-this
JWT_EXPIRES_IN=7d
