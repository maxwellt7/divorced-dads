# =============================================================================
# STAGING ENVIRONMENT — backend/.env.staging.example
# Copy to backend/.env when developing against the Railway staging environment.
# NEVER use production values here — staging must be isolated from prod data.
# =============================================================================

# --- Server ---
PORT=3001
NODE_ENV=staging
FRONTEND_URL=https://ai-hypnosis-generator-staging.vercel.app

# --- Feature flags ---
# Safe to enable/disable independently in staging without affecting production.
ENABLE_ANALYTICS=false
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_PINECONE=false

# --- Clerk (Auth) ---
# Ideally use a Clerk staging/test environment (pk_test_* / sk_test_*).
# If no staging Clerk env exists, the production keys can be shared with caution —
# sessions will still be isolated by JWT_SECRET differences.
CLERK_PUBLISHABLE_KEY=<clerk-staging-publishable-key>
CLERK_SECRET_KEY=<clerk-staging-secret-key>

# --- JWT (MUST differ from production — prevents session crossover) ---
JWT_SECRET=<generate-a-unique-staging-secret>
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=<generate-a-unique-staging-refresh-secret>
REFRESH_TOKEN_EXPIRES_IN=30d

# --- AI Models (safe to share keys — API calls are stateless) ---
ANTHROPIC_API_KEY=<shared-anthropic-key>

# --- ElevenLabs (safe to share keys) ---
ELEVENLABS_API_KEY=<shared-elevenlabs-key>
ELEVENLABS_VOICE_ID=<voice-id>
ELEVENLABS_VOICE_ID_SERAFINA=<serafina-voice-id>
ELEVENLABS_VOICE_ID_SILAS_VANE=<silas-vane-voice-id>
ELEVENLABS_VOICE_ID_VANE=<vane-voice-id>

# --- Go High Level CRM ---
# If GHL has a test sub-account, use those credentials here.
# Otherwise, staging calls will appear in the production GHL account.
GHL_API_KEY=<ghl-staging-api-key>
GHL_LOCATION_ID=<ghl-staging-location-id>

# --- Pinecone (when ENABLE_PINECONE=true) ---
# Use -staging suffixed index names to isolate from production data.
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_USER_INFO=user-information-staging
PINECONE_INDEX_KNOWLEDGE=core-hypnosis-knowledge-staging
PINECONE_INDEX_CREATIONS=past-creations-staging
PINECONE_INDEX_TRENDS=interest-trends-staging

# --- Stripe ---
# Use the Stripe test mode webhook secret (whsec_test_*).
# Configure in Stripe dashboard → Webhooks → Add endpoint → staging Railway URL.
STRIPE_WEBHOOK_SECRET=<stripe-test-webhook-secret>

# --- Meta CAPI (safe to share for staging) ---
META_CAPI_TOKEN=<meta-capi-token>

# --- Internal ---
# Used to authorize provisioning endpoints. Any random string is fine for staging.
PROVISION_SECRET=<random-string-for-staging>
CORS=*
NODE_VERSION=20
