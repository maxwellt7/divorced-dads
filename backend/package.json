{
  "name": "divorced-dads-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Backend API for Divorced Dads personal development app",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon -r dotenv/config server.js",
    "setup:db": "node scripts/setup-database.js",
    "setup:pinecone": "node scripts/setup-pinecone.js",
    "seed:knowledge": "node scripts/seed-knowledge.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.js\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.9.1",
    "@pinecone-database/pinecone": "^1.1.2",
    "mysql2": "^3.9.2",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "cohere-ai": "^7.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "googleapis": "^129.0.0",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.3.0",
    "nodemailer": "^6.9.7",
    "openai": "^4.24.1",
    "stripe": "^22.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3"
  },
  "keywords": [
    "divorced dads",
    "personal development",
    "ai coaching"
  ],
  "author": "Max Mayes",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.9.0"
  }
}
